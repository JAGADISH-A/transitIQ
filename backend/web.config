<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpplatformhandler" path="*" verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>
    <httpPlatform processPath="python"
                  stdoutLogEnabled="true"
                  stdoutLogFile="D:\home\LogFiles\python.log"
                  startupTimeLimit="60"
                  processesPerApplication="1">
      <environmentVariables>
        <environmentVariable name="PYTHONDONTWRITEBYTECODE" value="1" />
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
      </environmentVariables>
      <processes>
        <process command="gunicorn app.main:app --bind 0.0.0.0:%HTTP_PLATFORM_PORT% --workers 2 --worker-class uvicorn.workers.UvicornWorker --timeout 120">
        </process>
      </processes>
    </httpPlatform>
  </system.webServer>
</configuration>
